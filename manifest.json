{
  "manifest_version": 3,
  "name": "InstaCleanser",
  "version": "0.1.0",
  "description": "See who does not follow you back and manage follows using your Instagram session in the browser.",
  "homepage_url": "https://troydavis.me/instacleanser/",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "InstaCleanser",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": ["scripting", "activeTab", "storage", "sidePanel"],
  "host_permissions": ["https://www.instagram.com/*"]
}
